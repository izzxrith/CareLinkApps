<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:padding="32dp"
    tools:context=".LoginActivity">

    <!-- Logo -->
    <ImageView
        android:id="@+id/icon"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/intro_logo"
        android:background="@drawable/circle_green_112"
        android:elevation="6dp"
        android:padding="14dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- Title -->
    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome Back"
        android:textColor="#1B5E20"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Email -->
    <EditText
        android:id="@+id/inputEmail"
        android:layout_width="300dp"
        android:layout_height="58dp"
        android:hint="Enter your email"
        android:textColor="#000000"
        android:textColorHint="#757575"
        android:inputType="textEmailAddress"
        android:padding="16dp"
        android:background="@drawable/rounded_input"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Password -->
    <EditText
        android:id="@+id/inputPassword"
        android:layout_width="300dp"
        android:layout_height="58dp"
        android:hint="Enter your password"
        android:textColor="#000000"
        android:textColorHint="#757575"
        android:inputType="textPassword"
        android:padding="16dp"
        android:background="@drawable/rounded_input"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/inputEmail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Forgot -->
    <TextView
        android:id="@+id/tvForgot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Forgot Password?"
        android:textColor="#2E7D32"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/inputPassword"
        app:layout_constraintEnd_toEndOf="@id/inputPassword" />

    <!-- Login Button -->
    <Button
        android:id="@+id/btnLogin"
        android:layout_width="240dp"
        android:layout_height="60dp"
        android:text="Login"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textColor="@android:color/white"
        android:backgroundTint="#2E7D32"
        android:elevation="4dp"
        android:layout_marginTop="28dp"
        app:cornerRadius="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvForgot"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- OR -->
    <TextView
        android:id="@+id/or"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OR"
        android:textColor="#888888"
        android:textStyle="bold"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/btnLogin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Social Icons -->
    <LinearLayout
        android:id="@+id/socialRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/or"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnGoogle"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/social_circle"
            android:src="@drawable/google_logo" />

        <Space android:layout_width="20dp" android:layout_height="1dp"/>

        <ImageButton
            android:id="@+id/btnApple"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/social_circle"
            android:src="@drawable/apple_logo" />

        <Space android:layout_width="20dp" android:layout_height="1dp"/>

        <ImageButton
            android:id="@+id/btnFacebook"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/social_circle"
            android:src="@drawable/facebook_logo" />
    </LinearLayout>

    <!-- Sign Up -->
    <TextView
        android:id="@+id/tvSignUp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Don't have an account? Sign Up"
        android:textColor="#2E7D32"
        android:textStyle="bold"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/socialRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>