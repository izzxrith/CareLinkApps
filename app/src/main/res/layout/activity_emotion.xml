<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Analyzing your emotions..."
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Monitoring heart rate variability"
        android:textSize="14sp"
        android:textColor="@color/white_transparent"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <FrameLayout
        android:id="@+id/heartContainer"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/pulseRing3"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/circle_pulse"
            android:alpha="0" />

        <View
            android:id="@+id/pulseRing2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/circle_pulse"
            android:alpha="0" />

        <View
            android:id="@+id/pulseRing1"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/circle_pulse"
            android:alpha="0" />

        <ImageView
            android:id="@+id/ivHeart"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_heart_filled"
            app:tint="@color/heart_red" />

    </FrameLayout>

    <TextView
        android:id="@+id/tvHeartRate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="72 BPM"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/heartContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardResult"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvHeartRate"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">

                <ImageView
                    android:id="@+id/ivEmotionIcon"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:src="@drawable/ic_happy"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvEmotionResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Happy and Content"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/happy_yellow"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvAnalysis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Your gentle elevated heart rate suggests you're feeling positive and joyful."
                    android:textSize="16sp"
                    android:textColor="@color/dark_gray"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.2"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btnOkay"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Okay, Got It!"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/rounded_button"
                    android:elevation="4dp" />

            </LinearLayout>
        </ScrollView>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>