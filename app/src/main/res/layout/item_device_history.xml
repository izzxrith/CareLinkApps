<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_watch"
            android:background="@drawable/circle_green_light"
            android:padding="12dp"
            app:tint="@color/green"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tvDeviceType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WATCH"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvLinkId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID: abc123..."
                android:textSize="12sp"
                android:textColor="@color/gray"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvLinkedDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Linked: 30 Jan 2025"
                android:textSize="12sp"
                android:textColor="@color/dark_gray"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvDeviceStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="active"
            android:textStyle="bold"
            android:textColor="@color/green"
            android:background="@drawable/badge_green"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>